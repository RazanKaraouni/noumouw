# Copy to `.env` in this directory (never commit `.env`).
# If `.env` was previously tracked: git rm --cached website/backend/.env

NODE_ENV=development
PORT=5000
HOST=0.0.0.0

JWT_SECRET=YOUR_JWT_SECRET_HERE

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# Redis — required for OTP storage and distributed rate limits (see docker-compose.redis.yml)
REDIS_URL=redis://127.0.0.1:6379

# Local dev only (HTTP). Production must use HTTPS — see commented example below.
CORS_ORIGINS=http://localhost:5173

# Production: comma-separated HTTPS origins only (required when NODE_ENV=production)
# CORS_ORIGINS=https://your-frontend.onrender.com

# Public API base URL — required in production; must be HTTPS (emails, deep links)
PUBLIC_API_URL=https://your-api-domain.com

SMTP_HOST=YOUR_SMTP_HOST_HERE
SMTP_PORT=587
SMTP_USER=YOUR_SMTP_USER_HERE
SMTP_PASS=YOUR_SMTP_PASS_HERE
SMTP_FROM=noreply@example.com

ZOOM_ACCOUNT_ID=YOUR_ZOOM_ACCOUNT_ID_HERE
ZOOM_CLIENT_ID=YOUR_ZOOM_CLIENT_ID_HERE
ZOOM_CLIENT_SECRET=YOUR_ZOOM_CLIENT_SECRET_HERE

CHAT_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

# Firebase Admin — JSON string or path to service account file
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=

# Optional: direct Postgres URL for migration scripts
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD_HERE

# Sentry error monitoring (production recommended)
SENTRY_DSN=
