# Copy to `.env` in this directory (never commit `.env`).
# If `.env` was previously tracked: git rm --cached website/frontend/.env

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
# Local dev: omit VITE_API_URL to use the Vite proxy, or set:
# VITE_API_URL=http://localhost:5000/api
# Production build (required): HTTPS only
# VITE_API_URL=https://your-api-domain.com/api

VITE_APP_TIMEZONE=Asia/Beirut
VITE_ADMIN_APP_URL=http://localhost:5173
VITE_THERAPIST_APP_URL=http://localhost:5173
# Production:
# VITE_ADMIN_APP_URL=https://your-frontend.onrender.com
# VITE_THERAPIST_APP_URL=https://your-frontend.onrender.com
